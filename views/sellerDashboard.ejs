<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Seller Dashboard' %> | <%= seller.businessName || seller.fullName || 'SellerHub' %></title>
    <link rel="stylesheet" href="/css/dashboard.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>
    <div class="dashboard-wrapper">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-brand">
                <img src="/imgs/logo.png" alt="SellerHub" class="brand-logo">
                <span>SellerHub</span>
            </div>
            <nav class="sidebar-nav">
                <a href="/seller/dashboard" class="nav-item active">
                    <i class="fas fa-home"></i> Dashboard
                </a>
                <a href="/products/seller/list" class="nav-item">
                    <i class="fas fa-box"></i> Products
                </a>
                <a href="/seller/orders" class="nav-item">
                    <i class="fas fa-shopping-bag"></i> Orders
                    <% if (typeof newOrdersCount !== 'undefined' && newOrdersCount > 0) { %>
                    <span class="nav-badge"><%= newOrdersCount %></span>
                    <% } %>
                </a>
                <a href="/seller/earnings" class="nav-item">
                    <i class="fas fa-wallet"></i> Earnings
                </a>
                <a href="/products/seller/stock-alert" class="nav-item">
                    <i class="fas fa-bell"></i> Stock Alerts
                    <% if (stats && (stats.lowStockProducts > 0 || stats.outOfStockProducts > 0)) { %>
                    <span class="nav-badge alert"><%= (stats.lowStockProducts || 0) + (stats.outOfStockProducts || 0) %></span>
                    <% } %>
                </a>
                <a href="/seller/settings" class="nav-item">
                    <i class="fas fa-cog"></i> Settings
                </a>
            </nav>
            <div class="sidebar-footer">
                <a href="/seller/logout" class="nav-item logout">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Top Header -->
            <header class="top-header">
                <div class="header-search">
                    <i class="fas fa-search"></i>
                    <input type="text" placeholder="Search products, orders...">
                </div>
                <div class="header-actions">
                    <div class="header-icon">
                        <i class="fas fa-bell"></i>
                        <% if (typeof newOrdersCount !== 'undefined' && newOrdersCount > 0) { %>
                        <span class="icon-badge"><%= newOrdersCount %></span>
                        <% } %>
                    </div>
                    <div class="user-profile">
                        <img src="<%= seller.profileImageURL || '/imgs/default.png' %>" alt="Profile">
                        <div>
                            <strong><%= seller.fullName || 'Seller' %></strong>
                            <small><%= seller.businessName || seller.email %></small>
                        </div>
                    </div>
                </div>
            </header>

            <div class="content-area">
                <!-- Welcome Section -->
                <div class="welcome-section">
                    <div>
                        <h1>Welcome back, <%= seller.fullName || 'Seller' %>! 👋</h1>
                        <p>Here's what's happening with your store today.</p>
                    </div>
                    <div class="quick-actions">
                        <a href="/products/seller/add" class="btn btn-primary">
                            <i class="fas fa-plus"></i> Add Product
                        </a>
                        <a href="/seller/orders" class="btn btn-outline">
                            <i class="fas fa-box"></i> View Orders
                        </a>
                    </div>
                </div>

                <!-- Stats Grid -->
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-icon primary">
                            <i class="fas fa-box"></i>
                        </div>
                        <div class="stat-details">
                            <h3><%= (stats && stats.totalProducts) || 0 %></h3>
                            <p>Total Products</p>
                            <span class="stat-trend"><%= (stats && stats.activeProducts) || 0 %> active</span>
                        </div>
                    </div>

                    <div class="stat-card">
                        <div class="stat-icon success">
                            <i class="fas fa-rupee-sign"></i>
                        </div>
                        <div class="stat-details">
                            <h3><%= formatCurrency((stats && stats.totalRevenue) || 0) %></h3>
                            <p>Total Revenue</p>
                            <span class="stat-trend">Lifetime earnings</span>
                        </div>
                    </div>

                    <div class="stat-card">
                        <div class="stat-icon warning">
                            <i class="fas fa-exclamation-triangle"></i>
                        </div>
                        <div class="stat-details">
                            <h3><%= (stats && stats.lowStockProducts) || 0 %></h3>
                            <p>Low Stock</p>
                            <span class="stat-trend">Needs restock</span>
                        </div>
                    </div>

                    <div class="stat-card">
                        <div class="stat-icon danger">
                            <i class="fas fa-times-circle"></i>
                        </div>
                        <div class="stat-details">
                            <h3><%= (stats && stats.outOfStockProducts) || 0 %></h3>
                            <p>Out of Stock</p>
                            <span class="stat-trend">Urgent restock</span>
                        </div>
                    </div>

                    <% if (typeof wallet !== 'undefined' && wallet) { %>
                    <div class="stat-card">
                        <div class="stat-icon info">
                            <i class="fas fa-wallet"></i>
                        </div>
                        <div class="stat-details">
                            <h3><%= formatCurrency(wallet.availableBalance || 0) %></h3>
                            <p>Available Balance</p>
                            <span class="stat-trend"><%= formatCurrency(wallet.pendingBalance || 0) %> pending</span>
                        </div>
                    </div>
                    <% } %>

                    <% if (typeof newOrdersCount !== 'undefined' && newOrdersCount > 0) { %>
                    <div class="stat-card pulse">
                        <div class="stat-icon teal">
                            <i class="fas fa-shopping-cart"></i>
                        </div>
                        <div class="stat-details">
                            <h3><%= newOrdersCount %></h3>
                            <p>New Orders</p>
                            <span class="stat-trend"><a href="/seller/orders">Process now →</a></span>
                        </div>
                    </div>
                    <% } %>
                </div>

                <!-- Charts Row -->
                <% if ((typeof salesData !== 'undefined' && salesData && salesData.length > 0) || 
                       (typeof categoryData !== 'undefined' && categoryData && categoryData.length > 0)) { %>
                <div class="charts-row">
                    <% if (typeof salesData !== 'undefined' && salesData && salesData.length > 0) { %>
                    <div class="chart-card">
                        <div class="card-header">
                            <h3><i class="fas fa-chart-line"></i> Sales Overview</h3>
                        </div>
                        <div class="chart-body">
                            <canvas id="salesChart"></canvas>
                        </div>
                    </div>
                    <% } %>

                    <% if (typeof categoryData !== 'undefined' && categoryData && categoryData.length > 0) { %>
                    <div class="chart-card">
                        <div class="card-header">
                            <h3><i class="fas fa-chart-pie"></i> Sales by Category</h3>
                        </div>
                        <div class="chart-body">
                            <canvas id="categoryChart"></canvas>
                        </div>
                    </div>
                    <% } %>
                </div>
                <% } %>

                <!-- Tables Row -->
                <div class="tables-row">
                    <!-- Recent Products -->
                    <div class="data-card">
                        <div class="card-header">
                            <h3><i class="fas fa-clock"></i> Recent Products</h3>
                            <a href="/products/seller/list" class="link">View All →</a>
                        </div>
                        <div class="card-body">
                            <% if (recentProducts && recentProducts.length > 0) { %>
                            <div class="table-wrap">
                                <table class="data-table">
                                    <thead>
                                        <tr>
                                            <th>Product</th>
                                            <th>Price</th>
                                            <th>Stock Status</th>
                                            <th>Sales</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% recentProducts.forEach(product => { %>
                                        <tr>
                                            <td>
                                                <div class="product-info">
                                                    <img src="<%= product.thumbnail || '/images/placeholder-product.jpg' %>" 
                                                         alt="<%= product.title %>" class="product-thumb">
                                                    <div>
                                                        <strong><%= truncate(product.title, 40) %></strong>
                                                        <span class="text-muted"><%= product.category || 'Uncategorized' %> | <%= product.productType || 'N/A' %></span>
                                                    </div>
                                                </div>
                                            </td>
                                            <td><%= formatCurrency(product.sellingPrice) %></td>
                                            <td>
                                                <span class="status-badge <%= getStatusBadge(product.stockStatus) %>">
                                                    <%= product.stockStatus || 'N/A' %>
                                                </span>
                                            </td>
                                            <td><%= product.totalSales || 0 %></td>
                                        </tr>
                                        <% }) %>
                                    </tbody>
                                </table>
                            </div>
                            <% } else { %>
                            <div class="empty-state">
                                <i class="fas fa-box-open fa-3x"></i>
                                <h4>No products yet</h4>
                                <p>Add your first product to start selling.</p>
                                <a href="/products/seller/add" class="btn btn-primary">Add Product</a>
                            </div>
                            <% } %>
                        </div>
                    </div>

                    <!-- Top Selling -->
                    <div class="data-card">
                        <div class="card-header">
                            <h3><i class="fas fa-trophy"></i> Top Selling</h3>
                            <a href="/products/seller/list" class="link">View All →</a>
                        </div>
                        <div class="card-body">
                            <% if (topSelling && topSelling.length > 0) { %>
                            <div class="table-wrap">
                                <table class="data-table">
                                    <thead>
                                        <tr>
                                            <th>Rank</th>
                                            <th>Product</th>
                                            <th>Category</th>
                                            <th>Price</th>
                                            <th>Units</th>
                                            <th>Revenue</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% topSelling.forEach((product, index) => { %>
                                        <tr>
                                            <td><span class="rank-badge">#<%= index + 1 %></span></td>
                                            <td>
                                                <div class="product-info">
                                                    <img src="<%= product.thumbnail || '/images/placeholder-product.jpg' %>" 
                                                         alt="<%= product.title %>" class="product-thumb">
                                                    <strong><%= truncate(product.title, 35) %></strong>
                                                </div>
                                            </td>
                                            <td><%= product.category || 'N/A' %></td>
                                            <td><%= formatCurrency(product.sellingPrice) %></td>
                                            <td><%= product.totalSales || 0 %></td>
                                            <td><%= formatCurrency(product.totalRevenue || 0) %></td>
                                        </tr>
                                        <% }) %>
                                    </tbody>
                                </table>
                            </div>
                            <% } else { %>
                            <div class="empty-state">
                                <i class="fas fa-chart-bar fa-3x"></i>
                                <h4>No sales data yet</h4>
                                <p>Start selling to see your top products here.</p>
                            </div>
                            <% } %>
                        </div>
                    </div>
                </div>

                <!-- Stock Alert Banner -->
                <% if (stats && ((stats.lowStockProducts > 0) || (stats.outOfStockProducts > 0))) { %>
                <div class="alert-banner warning">
                    <i class="fas fa-exclamation-circle"></i>
                    <div>
                        <strong>Stock Alert:</strong> 
                        <%= stats.outOfStockProducts || 0 %> product(s) out of stock, 
                        <%= stats.lowStockProducts || 0 %> running low. 
                        <a href="/products/seller/stock-alert">Manage inventory →</a>
                    </div>
                </div>
                <% } %>
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        // Sales Chart
        <% if (typeof salesData !== 'undefined' && salesData && salesData.length > 0) { %>
        const salesCtx = document.getElementById('salesChart').getContext('2d');
        new Chart(salesCtx, {
            type: 'line',
            data: {
                labels: <%- JSON.stringify(salesData.map(d => d.month || d.label || '')) %>,
                datasets: [{
                    label: 'Revenue (₹)',
                    data: <%- JSON.stringify(salesData.map(d => d.amount || d.revenue || 0)) %>,
                    borderColor: '#4f46e5',
                    backgroundColor: 'rgba(79, 70, 229, 0.1)',
                    borderWidth: 2,
                    fill: true,
                    tension: 0.4,
                    pointRadius: 4,
                    pointBackgroundColor: '#4f46e5'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.05)' } },
                    x: { grid: { display: false } }
                }
            }
        });
        <% } %>

        // Category Chart
        <% if (typeof categoryData !== 'undefined' && categoryData && categoryData.length > 0) { %>
        const catCtx = document.getElementById('categoryChart').getContext('2d');
        new Chart(catCtx, {
            type: 'doughnut',
            data: {
                labels: <%- JSON.stringify(categoryData.map(d => d.name || d.category || '')) %>,
                datasets: [{
                    data: <%- JSON.stringify(categoryData.map(d => d.amount || d.value || 0)) %>,
                    backgroundColor: ['#4f46e5', '#10b981', '#f59e0b', '#ef4444', '#8b5cf6', '#ec4899', '#06b6d4'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '70%',
                plugins: {
                    legend: { position: 'bottom', labels: { usePointStyle: true, padding: 15 } }
                }
            }
        });
        <% } %>
    </script>
</body>
</html>
